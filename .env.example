# ── Notion ─────────────────────────────────────────────────
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_POSTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ANALYTICS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend Server ──────────────────────────────────────────
PORT=3001
STORAGE_PATH=./storage
LOG_LEVEL=info

# ── Frontend (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Scheduler ───────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_MINUTES=5

# ── MCP Server ──────────────────────────────────────────────
BACKEND_URL=http://localhost:3001

# ── Platform API Keys ───────────────────────────────────────
# Platform credentials are stored in storage/auth.enc (encrypted local vault)
# Set them via the `manage_platforms` MCP tool or the Platforms UI.
# Uncomment these only for direct testing:
# DEVTO_API_KEY=
# HASHNODE_API_KEY=
# HASHNODE_PUBLICATION_ID=
# MEDIUM_INTEGRATION_TOKEN=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# GHOST_URL=
# GHOST_ADMIN_API_KEY=
# WORDPRESS_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=
