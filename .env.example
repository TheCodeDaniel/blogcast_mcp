# BlogCast .env.example
#
# Almost nothing needs to be set here.
# Notion keys, platform API keys, and scheduler settings are all
# configured through the Settings page at localhost:5173/settings
# and stored encrypted on your local machine.
#
# Copy this file only if you want to override the defaults below.

# ── Server port (default: 3001) ──────────────────────────────────────────────
# PORT=3001

# ── Local storage path for images, queue, logs (default: ./storage) ─────────
# STORAGE_PATH=./storage

# ── Log level: error | warn | info | debug (default: info) ──────────────────
# LOG_LEVEL=info

# ── MCP server: backend URL (default: http://localhost:3001) ─────────────────
# Only needed if you change the port above.
# BACKEND_URL=http://localhost:3001

# ── CI / Docker overrides ────────────────────────────────────────────────────
# If you prefer env vars over the Settings UI (e.g. in a container), you can
# set these. They take priority over the vault.
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx
# NOTION_POSTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_ANALYTICS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
